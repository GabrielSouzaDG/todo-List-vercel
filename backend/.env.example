# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA suba o arquivo .env para o GitHub.

# String de conexão com o PostgreSQL
# Formato: postgres://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgres://usuario:senha@localhost:5432/todoapp

# URL do seu frontend no Vercel (para o CORS)
# Ex.: https://meu-todo-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Ambiente de execução: development | production
NODE_ENV=development

# Porta em que o servidor vai rodar localmente
PORT=3001
